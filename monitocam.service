[Unit]
Description=MonitoCam (Docker Compose)
After=network.target docker.service
Requires=docker.service

[Service]
Type=oneshot
User=cristian_martin
WorkingDirectory=/home/cristian_martin/personal-development/monitocam/monitocam
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose stop
RemainAfterExit=yes
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
