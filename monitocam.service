[Unit]
Description=MonitoCam Backend
After=network.target

[Service]
Type=simple
User=cristianmartin
WorkingDirectory=/home/cristianmartin/monitocam/backend

ExecStart=/home/cristianmartin/monitocam/backend/venv/bin/uvicorn src.main:app --host 0.0.0.0 --port 8585

Environment="PYTHONPATH=/home/cristianmartin/monitocam/backend/src"

Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
